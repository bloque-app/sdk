{
  "name": "@bloque/cli",
  "version": "0.1.0",
  "description": "Bloque CLI — authenticate and expose SDK capabilities as an MCP server",
  "type": "module",
  "bin": {
    "bloque": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "compile": "bun run compile:darwin-arm64 && bun run compile:darwin-x64 && bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:windows-x64",
    "compile:darwin-arm64": "bun build src/bin.ts --compile --target=bun-darwin-arm64 --outfile=dist/bloque-darwin-arm64",
    "compile:darwin-x64": "bun build src/bin.ts --compile --target=bun-darwin-x64 --outfile=dist/bloque-darwin-x64",
    "compile:linux-x64": "bun build src/bin.ts --compile --target=bun-linux-x64 --outfile=dist/bloque-linux-x64",
    "compile:linux-arm64": "bun build src/bin.ts --compile --target=bun-linux-arm64 --outfile=dist/bloque-linux-arm64",
    "compile:windows-x64": "bun build src/bin.ts --compile --target=bun-windows-x64 --outfile=dist/bloque-windows-x64.exe",
    "release": "bun ../../scripts/safe-publish.ts",
    "dev": "bun run src/bin.ts",
    "start": "node dist/bin.js",
    "typecheck": "tsc --noEmit"
  },
  "tsup": {
    "entry": [
      "src/bin.ts"
    ],
    "format": [
      "esm"
    ],
    "target": "node22",
    "outDir": "dist",
    "clean": true,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  },
  "dependencies": {
    "@bloque/sdk": "workspace:*",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  }
}