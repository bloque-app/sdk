{
  "name": "@bloque/cli",
  "version": "0.0.1",
  "description": "Bloque CLI — authenticate and expose SDK capabilities as an MCP server",
  "type": "module",
  "bin": {
    "bloque": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "bun run src/bin.ts",
    "start": "node dist/bin.js",
    "typecheck": "tsc --noEmit"
  },
  "tsup": {
    "entry": ["src/bin.ts"],
    "format": ["esm"],
    "target": "node22",
    "outDir": "dist",
    "clean": true,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  },
  "dependencies": {
    "@bloque/sdk": "workspace:*",
    "@inquirer/prompts": "^7.5.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  }
}
