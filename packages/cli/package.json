{
  "name": "@bloque/cli",
  "version": "0.1.10",
  "description": "Bloque CLI — authenticate and expose SDK capabilities as an MCP server",
  "type": "module",
  "keywords": [
    "bloque",
    "cli"
  ],
  "bin": {
    "bloque": "./bin/npm.cjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./bin/npm.cjs",
  "files": [
    "dist",
    "bin/npm.cjs"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "build:release": "bun run build.ts && bun run scripts/package-release.ts",
    "dev": "bun run src/bin.ts",
    "start": "node dist/bin.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bloque/sdk": "workspace:*",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  }
}
